fn main(): int {
  x: int = 1;
  y: int = 2;

  // else should bind to the nearest if.
  if (x < 0)
    if (y > 0)
      output(111); // expect: not printed
    else
      output(222); // expect: not printed

  if (x < y)
    output(1); // expect: 1
  else
    output(0); // expect: not printed

  return 0;
}
