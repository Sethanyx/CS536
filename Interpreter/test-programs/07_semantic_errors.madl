fn id(x: int): int {
  return x;
}

fn main(): int {
  a: int = 10;

  // Runtime semantic checks (interpreter side):
  // 1) Type mismatch:
  output(a < 5); // expect: runtime type error (output expects int)

  // 2) Unbound reference:
  // output(not_defined_var); // expect: runtime unbound reference error

  // 3) Arithmetic error:
  // output(a / (3 - 3)); // expect: runtime division-by-zero error

  // Depending on your error handling, execution may stop at first error.
  return id(a);
}
